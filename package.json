{
  "name": "vibe-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/core/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "dashboard": "DASHBOARD_PORT=3333 tsx src/dashboard/server.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@anthropic-ai/sdk": "^0.79.0",
    "@google/genai": "^1.46.0",
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.19.11",
    "@libsql/client": "^0.17.0",
    "@mastra/core": "^1.15.0",
    "@notionhq/client": "^5.13.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "google-ads-api": "^23.0.0",
    "googleapis": "^171.4.0",
    "hono": "^4.12.8",
    "node-cron": "^4.2.1",
    "resend": "^6.9.4",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
